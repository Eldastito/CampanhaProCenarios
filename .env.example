# ============================================================================
# FORGE Scenario Lab — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# Do NOT commit .env (it's already in .gitignore).
# After editing .env, restart with: docker compose up --build

# ----------------------------------------------------------------------------
# AI Provider Keys (at least ONE is required for graph/simulation/research)
# ----------------------------------------------------------------------------

# OpenAI (preferred — used by Research Agent and graph extraction)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (fallback if OpenAI not set)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
