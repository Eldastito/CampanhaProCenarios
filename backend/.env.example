APP_NAME=FORGE Scenario Lab API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=forge_scenario_lab
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Security secrets (CHANGE ALL VALUES IN PRODUCTION) ---

# Server-to-server secret shared with the FORGE platform (X-Forge-Secret header)
FORGE_INGEST_SHARED_SECRET=dev-forge-secret

# Internal API key for service-to-service calls (X-API-Key header)
INTERNAL_API_KEY=dev-internal-key

# JWT signing secret — use a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=dev-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
